# Top-level Git ignore for ratatui-ts workspace

# Ignore the nested ratatui-ffi repository entirely

# Node / TypeScript artifacts
node_modules/
dist/
*.tsbuildinfo
coverage/
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# Lockfile intentionally untracked (CI installs fresh; remote never tracked one)
package-lock.json

# Native lib dropped by scripts/postinstall.js at install time — an artifact,
# never source. The org publish checklist forbids tracked .so files.
native/

# Env files
.env
.env.*

# Editor/OS
.DS_Store
.idea/
.vscode/

# Misc caches
.eslintcache
.turbo/

